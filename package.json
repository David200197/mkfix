{
  "name": "mkfix",
  "version": "1.0.0",
  "description": "A CLI tool to quickly apply AI-suggested code changes from JSON configuration files",
  "main": "bin/mkfix.js",
  "bin": {
    "mkfix": "./bin/mkfix.js"
  },
  "scripts": {
    "mkfix": "node bin/mkfix.js",
    "mkfix:skill": "node bin/mkfix.js --skill",
    "mkfix:ds": "node bin/mkfix.js -ds",
    "mkfix:config": "node bin/mkfix.js --config",
    "mkfix:help": "node bin/mkfix.js --help",
    "restore-backup": "node scripts/restore-backup.js"
  },
  "keywords": [
    "cli",
    "code-fix",
    "ai",
    "automation",
    "code-changes"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "prompt": "^1.3.0"
  }
}
